{
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": "-- Grafana --",
                "enable": true,
                "hide": true,
                "iconColor": "rgba(0, 211, 255, 1)",
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "editable": true,
    "gnetId": null,
    "graphTooltip": 0,
    "id": null,
    "links": [],
    "panels": [
        {
            "title": "API Request Rate",
            "type": "graph",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rate(http_request_duration_seconds_count[5m])",
                    "legendFormat": "{{path}}"
                }
            ]
        },
        {
            "title": "API Latency (P95)",
            "type": "graph",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, path))",
                    "legendFormat": "{{path}}"
                }
            ]
        },
        {
            "title": "Error Rate (5xx)",
            "type": "graph",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "sum(rate(http_request_duration_seconds_count{status=~\"5..\"}[5m]))",
                    "legendFormat": "Errors"
                }
            ]
        },
        {
            "title": "Memory Usage (MB)",
            "type": "graph",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "targets": [
                {
                    "expr": "process_resident_memory_bytes / 1024 / 1024",
                    "legendFormat": "Memory"
                }
            ]
        }
    ],
    "schemaVersion": 22,
    "style": "dark",
    "tags": [
        "FastAPI",
        "ERP"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "title": "AcademiaOS - Production Monitoring",
    "uid": "prod-monitoring",
    "version": 1
}